rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Signed-in users can read/write fleet data (tighten for production, e.g. by role in custom claims)
    match /users/{docId} {
      allow read, write: if request.auth != null;
    }
    match /vehicles/{docId} {
      allow read, write: if request.auth != null;
    }
    match /drivers/{docId} {
      allow read, write: if request.auth != null;
    }
    match /insurance/{docId} {
      allow read, write: if request.auth != null;
    }
    match /fuel_logs/{docId} {
      allow read, write: if request.auth != null;
    }
    match /notifications/{docId} {
      allow read, write: if request.auth != null;
    }
    match /vehicle_disposal/{docId} {
      allow read, write: if request.auth != null;
    }
  }
}
